# Game server
PORT=3001
HOST=0.0.0.0
DATABASE_PATH=./data/shengji.sqlite
DEAL_INTERVAL_MS=45

# Optional custom-room defaults (v1 UI still presents one preset)
# BID_POST_DEAL_SECONDS=30
# BID_RESPONSE_SECONDS=15

# Next.js server-side API proxy
GAME_SERVER_ORIGIN=http://localhost:3001

# Optional browser WebSocket endpoint, useful behind a custom proxy
# NEXT_PUBLIC_WS_URL=wss://play.example.com/ws
