{
  "name": "shengji-online",
  "version": "0.1.0",
  "private": true,
  "description": "A ruleset-driven online multiplayer Sheng Ji game",
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:packages": "pnpm --filter @shengji/engine build && pnpm --filter @shengji/protocol build",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "dev": "pnpm --parallel --filter @shengji/server --filter @shengji/web dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm build:packages && eslint .",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @shengji/e2e e2e",
    "test:watch": "pnpm --filter @shengji/engine test:watch",
    "start": "pnpm --parallel --filter @shengji/server --filter @shengji/web start",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.5.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9"
  }
}
